        <mxCell id="-BKJ1onnYNfLf-bJvCuk-38" value="Uses a knowledge graph to represent long term fire fighting strategy and adapt to user override requests. Sends commands to the dispatch agent." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
