        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-14" value="Stochastic Cellular Automata is used to simulate the propagation of wildfire. Takes into account vegetation type, and wind factors. Wind is assumed static." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
