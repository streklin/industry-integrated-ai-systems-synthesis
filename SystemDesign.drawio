        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-40" value="Allows a human user to inquire about the state of the fire fighting process as well as reprioritize the current goals." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
