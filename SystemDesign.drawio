        <mxCell id="-BKJ1onnYNfLf-bJvCuk-18" value="Recon Agent" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-180" y="525" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-19" value="Fire Fighting Agent" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-360" y="525" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-20" value="Dispatch Agent" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-360" y="685" width="350" height="60" as="geometry" />
        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-25" value="Rules based Agents. The Dispatch Agent provides waypoints for these drones. Dispatch Agent only has a limited number of each drone type available. (More Recon drones than fire-fighting drones are available)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="525" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-28" value="A Decision Transformer RL Agent is used to combine visual data from the Risk Predication model, reports from the UAV&#39;s and user priorities to allocate UAV resources to the appropriate fire fighting zones." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="675" width="300" height="60" as="geometry" />
        </mxCell>
