        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-16" value="A semantic segmentation model (UNet) is used to label risk level of each cell. i.e. which cells are in danger of buring down in the forseeable future." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
