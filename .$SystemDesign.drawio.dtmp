        <mxCell id="yNSJN4WaUu4dFpf9RqAE-3" value="Long Term Planner takes input both from periodic updates via Environmental / Risk Image snapshots as well as from Human Operator Instructuctions (via the chatbot)." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
