        </mxCell>
        <mxCell id="-BKJ1onnYNfLf-bJvCuk-15" value="A handful of humans are simulated as doing a random walk through the forest when the fire starts." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
