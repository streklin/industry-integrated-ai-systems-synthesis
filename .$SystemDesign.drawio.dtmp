        <mxCell id="-BKJ1onnYNfLf-bJvCuk-52" value="Both modules can read and write to the underlying knowledge graph." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
